root = true

[*]
indent_size = 2
indent_style = space

[*.cs]
indent_size = 2
indent_style = space
csharp_new_line_before_open_brace = none

dotnet_naming_style.camel_case_style.capitalization = camel_case
dotnet_naming_symbols.local_variables_symbols.applicable_kinds = local
dotnet_naming_rule.local_variables_rule.symbols = local_variables_symbols
dotnet_naming_rule.local_variables_rule.style = camel_case_style
dotnet_naming_rule.local_variables_rule.severity = error

csharp_style_var_for_built_in_types = false:error
csharp_style_var_when_type_is_apparent = false:error
csharp_style_var_elsewhere = false:error
# Поля с подчёркиванием разрешены (_factories, _random, _peopleCount)
dotnet_diagnostic.SA1309.severity = none

# Префикс this. не обязателен
dotnet_diagnostic.SA1101.severity = none

# using могут быть вне namespace
dotnet_diagnostic.SA1200.severity = none

# Заголовок файла не обязателен
dotnet_diagnostic.SA1633.severity = none

# Скобки в стиле OTBS (на той же строке)
dotnet_diagnostic.SA1500.severity = none

# XML-комментарии не обязательны
dotnet_diagnostic.SA0001.severity = none

# Первичные конструкторы
dotnet_diagnostic.IDE0290.severity = none
# Упрощение коллекций (new List<> → [])
dotnet_diagnostic.IDE0028.severity = none